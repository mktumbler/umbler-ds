{
  "name": "@umbler/ui",
  "version": "0.1.0",
  "description": "Umbler Design System — componentes React + tokens Tailwind v4.",
  "license": "UNLICENSED",
  "type": "module",
  "sideEffects": [
    "*.css"
  ],
  "scripts": {
    "prepack": "node ../../scripts/build-package.mjs"
  },
  "files": [
    "src",
    "tokens.css",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./tokens.css": "./tokens.css",
    "./*": {
      "types": "./src/*.tsx",
      "default": "./src/*.tsx"
    }
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/umbler/umbler-ds.git",
    "directory": "packages/ui"
  },
  "peerDependencies": {
    "react": ">=19",
    "react-dom": ">=19"
  },
  "dependencies": {
    "@phosphor-icons/react": "^2.1.7",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "tailwind-merge": "^2.5.5"
  }
}
